# x402-go-client-example Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
CLIENT_LOG_LEVEL=info

# Enable JSON logging format (useful for log aggregation)
CLIENT_LOG_JSON=false

# =============================================================================
# SIGNING / WALLET
# =============================================================================

# Ethereum private key for signing payment authorizations
# WARNING: Keep this secret! Never commit real private keys.
# Format: hex string with or without 0x prefix
# Example (TEST KEY - DO NOT USE IN PRODUCTION):
# CLIENT_PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CLIENT_PRIVATE_KEY=

# =============================================================================
# PAYMENT POLICY
# =============================================================================

# Maximum payment amount allowed (in smallest unit, e.g., wei or USDC's 6 decimals)
# Default: 1000000 (1 USDC with 6 decimals)
CLIENT_MAX_AMOUNT=1000000

# Comma-separated list of allowed asset identifiers
# Leave empty to allow all assets
# Example: USDC,ETH
CLIENT_ALLOWED_ASSET=

# Allowed blockchain chain/network ID
# Leave empty to allow all chains
# Examples:
#   1      = Ethereum Mainnet
#   84532  = Base Sepolia
#   8453   = Base Mainnet
#   137    = Polygon Mainnet
CLIENT_ALLOWED_CHAIN_ID=

# Comma-separated list of allowed payment recipient addresses
# Leave empty to allow all recipients
# Example: 0x1234...,0x5678...
CLIENT_ALLOWED_PAY_TO=

# =============================================================================
# HTTP CLIENT
# =============================================================================

# Request timeout (Go duration format: 30s, 1m, etc.)
CLIENT_TIMEOUT=30s

# =============================================================================
# BEHAVIOR FLAGS
# =============================================================================

# Dry-run mode: Parse 402 and validate policy, but don't sign or retry
CLIENT_DRY_RUN=false

# No-pay mode: Don't attempt payment flow at all (just show 402)
CLIENT_NO_PAY=false

# =============================================================================
# MULTI-OPTION SELECTION PREFERENCES
# =============================================================================

# Preferred blockchain networks (CAIP-2 format, comma-separated)
# The client will prefer options on these networks when multiple are offered.
# Bare chain IDs are auto-normalized to CAIP-2 (e.g., 84532 -> eip155:84532).
# Example: eip155:47763,eip155:84532  (prefer Neo X, then Base Sepolia)
CLIENT_PREFERRED_NETWORKS=

# Preferred asset addresses (comma-separated)
# Example: 0xABCDEF0000000000000000000000000000000001,0x036CbD53842c5426634e7929541eC2318f3dCF7e
CLIENT_PREFERRED_ASSETS=

# Preferred transfer methods (comma-separated)
# Supported: eip3009 (transferWithAuthorization), permit2
# Example: eip3009,permit2
CLIENT_PREFERRED_TRANSFER_METHODS=

# Option selection strategy:
#   server-order     = Try options in the order the server provides (default, backward compatible)
#   preference-first = Reorder options by preferences before applying policy checks
CLIENT_SELECTION_STRATEGY=server-order
