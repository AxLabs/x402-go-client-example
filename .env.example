# x402-go-client-example Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
CLIENT_LOG_LEVEL=info

# Enable JSON logging format (useful for log aggregation)
CLIENT_LOG_JSON=false

# =============================================================================
# SIGNING / WALLET
# =============================================================================

# Ethereum private key for signing payment authorizations
# WARNING: Keep this secret! Never commit real private keys.
# Format: hex string with or without 0x prefix
# Example (TEST KEY - DO NOT USE IN PRODUCTION):
# CLIENT_PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CLIENT_PRIVATE_KEY=

# =============================================================================
# PAYMENT POLICY
# =============================================================================

# Maximum payment amount allowed (in smallest unit, e.g., wei or token decimals)
# Leave empty for no client-side amount ceiling.
# Example: 50000000000000000 = 0.05 xGAS
CLIENT_MAX_AMOUNT=

# Comma-separated list of allowed asset identifiers
# Leave empty to allow all assets
# Example: USDC,ETH,xGAS
# Leave empty to allow all assets, or list both Base Sepolia tokens:
CLIENT_ALLOWED_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e,0xEdF8a988A61849ce611E932d03D0Bac066304F59

# Allowed blockchain chain/network ID
# Leave empty to allow all chains
# Examples:
#   1      = Ethereum Mainnet
#   137    = Polygon Mainnet
#   8453   = Base Mainnet
#   47763  = Neo X Mainnet
#   84532  = Base Sepolia
#   12227332 = Neo X Testnet
CLIENT_ALLOWED_CHAIN_ID=eip155:84532

# Comma-separated list of allowed payment recipient addresses
# Leave empty to allow all recipients
# Example: 0x1234...,0x5678...
CLIENT_ALLOWED_PAY_TO=

# =============================================================================
# HTTP CLIENT
# =============================================================================

# Request timeout (Go duration format: 30s, 1m, etc.)
CLIENT_TIMEOUT=30s

# =============================================================================
# BEHAVIOR FLAGS
# =============================================================================

# Dry-run mode: Parse 402 and validate policy, but don't sign or retry
CLIENT_DRY_RUN=false

# No-pay mode: Don't attempt payment flow at all (just show 402)
CLIENT_NO_PAY=false

# =============================================================================
# MULTI-OPTION SELECTION PREFERENCES
# =============================================================================

# Preferred blockchain networks (CAIP-2 format, comma-separated)
# The client will prefer options on these networks when multiple are offered.
# Bare chain IDs are auto-normalized to CAIP-2 (e.g., 84532 -> eip155:84532).
# Example: eip155:47763,eip155:8453 (prefer Neo X, then Base)
CLIENT_PREFERRED_NETWORKS=eip155:84532,eip155:12227332

# Preferred asset addresses (comma-separated, first = highest priority)
CLIENT_PREFERRED_ASSETS=0x036CbD53842c5426634e7929541eC2318f3dCF7e,0xEdF8a988A61849ce611E932d03D0Bac066304F59

# Preferred transfer methods (comma-separated)
# USDC uses eip3009; ZCHF (Frankencoin) uses permit2.
CLIENT_PREFERRED_TRANSFER_METHODS=eip3009,permit2

# EIP-3009 domain override (optional)
# Use only for eip3009 when server-provided requirements.extra.name/version are
# incorrect for the token contract domain.
#
# xGAS (Neo X) example domain:
# {
#   "name": "Extended GAS",
#   "version": "1",
#   "chainId": 47763,
#   "verifyingContract": "<xgas contract address>"
# }
# Permit2 note: Permit2 uses its own contract EIP-712 domain. The overrides
# above are intended for eip3009 token-domain correction.

# =============================================================================
# EVM RPC (required for automatic Permit2 approve before ZCHF payments)
# =============================================================================
# Default JSON-RPC for on-chain reads and approve(Permit2) transactions.
CLIENT_RPC_URL=https://sepolia.base.org
# Optional per-network override (colons in CAIP-2 become underscores):
# CLIENT_RPC_EIP155_84532=https://sepolia.base.org
# CLIENT_RPC_EIP155_12227332=https://neoxt4seed1.ngd.network/

# Option selection strategy:
#   server-order     = Try options in the order the server provides (default, backward compatible)
#   preference-first = Reorder options by preferences before applying policy checks
CLIENT_SELECTION_STRATEGY=preference-first

# =============================================================================
# END-TO-END TESTING (optional)
# =============================================================================

# E2E tests are skipped by default. Set these to run them against a real server.

# URL of a running x402-go-server-example instance
# X402_E2E_SERVER_URL=http://localhost:8080

# Private key for paid E2E tests (never commit real keys)
# X402_E2E_PRIVATE_KEY=0x...
